# Copy to `.env` and fill in real values. Never commit `.env`.
# See README.md and `src/config/env.ts` for defaults.

NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017/trading-automation
MONGODB_DB=trading-automation

# --- Pinecone (pattern memory; cosine index, 1536 dims) ---
PINECONE_API_KEY=
PINECONE_INDEX=trading-patterns
PINECONE_NAMESPACE=golden-patterns
# Weekend optimize (`bun run weekend-optimize`): Pinecone id skip + Mongo per-ticker resume (see docs/weekend-playbook.md)
WEEKEND_OPTIMIZE_SKIP_EXISTING=true
WEEKEND_OPTIMIZE_RESUME=true
WEEKEND_OPTIMIZE_FETCH_BATCH=100

# --- Embeddings (optional; if empty, deterministic vectors are used for patterns) ---
# OPENAI_API_KEY=
# Or use a generic key name:
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1

# --- Judge (OpenRouter or OpenAI-compatible chat) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
JUDGE_MODEL=deepseek/deepseek-chat
JUDGE_MODEL_BACKTEST=google/gemini-2.0-flash-001
OPS_AI_MODEL=google/gemma-4-31b-it:free
# Ops CLI: scan last N trading days and list missing artifacts for guided repair.
OPS_MISSING_TRADING_DAYS_LOOKBACK=10
# Funnel optimizer (decision-funnel auto-tuning helper; safe weekly cap)
FUNNEL_OPTIMIZER_LOOKBACK_DAYS=5
FUNNEL_OPTIMIZER_MIN_DECISIONS=120
FUNNEL_OPTIMIZER_DOMINANCE_PCT=0.35
FUNNEL_OPTIMIZER_MAX_CHANGES_PER_WEEK=1
# Phase 8 validation targets (kpi pass/fail)
PHASE8_VALIDATION_LOOKBACK_DAYS=5
PHASE8_TARGET_EXEC_RATE_MIN=0.02
PHASE8_TARGET_EXEC_RATE_MAX=0.05
PHASE8_TARGET_LOSING_DAY_PCT_MAX=0.30
PHASE8_TARGET_REPLAY_PF_MIN=1.20
PHASE8_TARGET_MAX_DAILY_LOSS=15000

# --- Historical news replay (backtest) ---
HISTORICAL_NEWS_PATH=data/historical_news.json
# Live RSS for news_context (default: ET markets/stocks feed)
# NEWS_ET_RSS_URL=https://economictimes.indiatimes.com/markets/stocks/rssfeeds/2146842.cms
# Hybrid HTML scrape (Moneycontrol) merged with RSS in fetchTodayNewsContext — set false to RSS-only
# NEWS_SENTINEL=false
# SENTINEL_MC_URL=https://www.moneycontrol.com/news/business/markets/
# SENTINEL_TIMEOUT_MS=15000
# Retries for RSS / Moneycontrol / ET archive (5xx, 429, transient network)
# SENTINEL_MAX_RETRIES=4
# SENTINEL_RETRY_BASE_MS=700
# Delay between ET archive day requests (backfill-news-scraper)
# ARCHIVE_SCRAPER_DELAY_MS=2500
# Replay prep: before judge-enabled backtest runs, auto-fetch ET archive for replay weekdays
# and upsert into news_archive/news_context with headline-level dedup (no duplicate headlines per day).
# BACKTEST_NEWS_AUTO_BACKFILL=true
# BACKTEST_NEWS_MIN_HEADLINES_PER_DAY=8
# BACKTEST_NEWS_AUTO_BACKFILL_NO_FILTER=false

# --- Angel One SmartAPI ---
ANGEL_API_KEY=
ANGEL_API_SECRET=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
TOTP_SEED=
ANGEL_CLIENT_LOCAL_IP=192.168.1.1
ANGEL_CLIENT_PUBLIC_IP=127.0.0.1
ANGEL_MAC_ADDRESS=00:00:00:00:00:00
ANGEL_EXCHANGE=NSE
# Slow down historical candle fetches if Angel returns 403 rate limit
# ANGEL_API_THROTTLE_MS=450
# ANGEL_SYNC_TICKER_GAP_MS=800
# SmartAPI shared limiter (recommended: use this instead of large fixed sleeps)
# ANGEL_HTTP_MIN_GAP_MS=300
# ANGEL_HTTP_MAX_CONCURRENCY=1
# ANGEL_HTTP_403_RETRIES=2
# ANGEL_HTTP_429_RETRIES=2
# ANGEL_HTTP_403_RETRY_BASE_MS=1500
# ANGEL_HTTP_RATE_LIMIT_COOLDOWN_MS=1500
# ANGEL_HTTP_MAX_BACKOFF_MS=30000
# ANGEL_HTTP_RETRY_JITTER_MS=200
# ANGEL_HTTP_LOG_LIMITER=false

# --- Risk & execution ---
# PAPER = no real exchange orders from this app. LIVE = real placeOrder when broker is wired.
EXECUTION_ENV=PAPER
DAILY_STOP_LOSS=15000
MAX_CONCURRENT_TRADES=5
MAX_SECTOR_POSITIONS=2
MAX_SAME_SIDE_POSITIONS=3
MAX_CORRELATION_WITH_OPEN=0.70
CORRELATION_LOOKBACK_DAYS=20
MAX_GROSS_EXPOSURE_PCT=1.5
MAX_BETA_EXPOSURE_PCT=2.0
# If true, qty is reduced to fit exposure headroom before hard-blocking.
EXPOSURE_FIT_SIZING_ENABLED=true
ROLLING_3D_DRAWDOWN_LIMIT=40000
WEEKLY_DRAWDOWN_LIMIT=50000
CONSECUTIVE_LOSS_THROTTLE=3
LOSS_THROTTLE_SIZE_MULTIPLIER=0.5
# Soft throttles: keep catastrophic blocks hard, downsize mild portfolio breaches.
RISK_SOFT_THROTTLES_ENABLED=true
SOFT_SECTOR_OVERFLOW_SIZE_MULTIPLIER=0.75
SOFT_SAME_SIDE_OVERFLOW_SIZE_MULTIPLIER=0.65
SOFT_CORRELATION_HARD_BLOCK=0.90
SOFT_CORRELATION_MIN_SIZE_MULTIPLIER=0.50
MARKET_GATE_ENABLED=true
MARKET_BLOCK_LONG_BREAKOUTS_NIFTY_PCT=-1.0
MARKET_BLOCK_LONG_BREAKOUTS_BREADTH=0.3
MARKET_WEAK_NIFTY_PCT=-0.5
MARKET_WEAK_BREADTH=0.4
MARKET_WEAK_SIZE_MULTIPLIER=0.5
MARKET_WEAK_CONFIDENCE_FLOOR=0.62
TIME_WINDOWS_ENABLED=true
NO_FRESH_ENTRIES_AFTER=14:30
ORB_ENTRY_START=09:30
ORB_ENTRY_END=12:00
VWAP_ENTRY_START=10:00
VWAP_ENTRY_END=14:30
MEAN_REV_ENTRY_START=10:00
MEAN_REV_ENTRY_END=14:30
DEFAULT_ENTRY_START=09:30
DEFAULT_ENTRY_END=14:30
# Session policy: stricter open, normal midday, conservative late session.
SESSION_POLICY_ENABLED=true
SESSION_OPEN_STRICT_START=09:30
SESSION_OPEN_STRICT_END=10:30
SESSION_OPEN_SIZE_MULTIPLIER=0.80
SESSION_OPEN_CONFIDENCE_FLOOR=0.52
SESSION_MID_START=10:30
SESSION_MID_END=13:30
SESSION_MID_SIZE_MULTIPLIER=1.00
SESSION_MID_CONFIDENCE_FLOOR=0.46
SESSION_LATE_START=13:30
SESSION_LATE_END=15:00
SESSION_LATE_SIZE_MULTIPLIER=0.75
SESSION_LATE_CONFIDENCE_FLOOR=0.55
SESSION_LOW_CONVICTION_BLOCK_AFTER=15:00
SESSION_LOW_CONVICTION_MIN_CONFIDENCE=0.62
EMA20_RETEST_MIN_VOLUME_Z=0
VWAP_CONTINUATION_MIN_VOLUME_Z=0
RETEST_MAX_BARS_AFTER_BREAK=20
ORB_FAKEOUT_CONFIRMATION_BARS=2
WATCHED_TICKERS=RELIANCE,TCS,INFY
TRADING_TICKER_SOURCE=active_watchlist
# DISCOVERY_SYMBOL_DELAY_MS=2000
# QUOTE_BATCH_DELAY_MS=1100
# NIGHTLY_DISCOVERY=false
# End-of-day daemon jobs (single-process mode; PM2 cron jobs optional)
# DAEMON_EVENING_JOBS_ENABLED=true
# DAEMON_EVENING_LIVE_ANALYZE_AT=15:35
# DAEMON_EVENING_ANALYST_AT=15:45
# PREOPEN_PIVOT=false
# PREOPEN_JUDGE=false
# PREOPEN_MIN_ABS_GAP_PCT=1.5
# PREOPEN_MIN_VOL_VS_AVG=0.2
# PREOPEN_MAX_CANDIDATES=50
# PREOPEN_MAX_PICKS=10

# --- HTTP health / emergency ---
HEALTH_PORT=3000
# Optional: enable POST /v1/emergency/square-off with header X-Emergency-Key
# EMERGENCY_SQUARE_OFF_SECRET=

# --- Benchmark ---
NIFTY_BENCHMARK_TICKER=NIFTY50

# --- Live-only: judge throttle & Pinecone gate ---
JUDGE_COOLDOWN_MS=900000
# Adaptive cooldown: higher-quality candidates wait less, weaker candidates wait more.
ADAPTIVE_JUDGE_COOLDOWN_ENABLED=true
ADAPTIVE_JUDGE_COOLDOWN_MIN_MS=60000
ADAPTIVE_JUDGE_COOLDOWN_MAX_MS=300000
# Short retry cooldown for hard risk-vetoed strategy:ticker pairs
RISK_VETO_RETRY_COOLDOWN_MS=60000
# After any position exit (stop/target/forced), block re-entry on that ticker for this long (ms).
# 20 min default prevents flip-flop entries immediately after a stop-out.
TICKER_REENTRY_COOLDOWN_MS=720000
# Rank and limit per-ticker candidates before full decisioning.
CANDIDATE_QUEUE_ENABLED=true
MAX_CANDIDATES_PER_TICKER=2
# Allow replacing weakest open position when book is full and incoming quality is better.
REPLACEMENT_ENABLED=true
REPLACEMENT_MIN_SCORE_DELTA=0.15
REPLACEMENT_MIN_CONFIDENCE=0.65
LIVE_SKIP_JUDGE=false
LIVE_DEBUG_SCANS=true
LIVE_EXEC_SYNC_ENABLED=true
LIVE_EXEC_SYNC_INTERVAL_MINUTES=10
LIVE_EXEC_SYNC_LOOKBACK_MINUTES=180
LIVE_EXEC_TICKER_RESYNC_COOLDOWN_MINUTES=10
PINECONE_GATE_ENABLED=true
PINECONE_GATE_MIN_SCORE=0.98
PINECONE_GATE_MIN_NEIGHBORS=3
PINECONE_GATE_CONSENSUS_MIN_SCORE=0.85
PINECONE_GATE_MIN_WIN_RATE=0.60
PINECONE_GATE_REQUIRE_SAME_STRATEGY=true
PINECONE_GATE_SAME_SECTOR_WEIGHT=1.2
PINECONE_GATE_SAME_REGIME_WEIGHT=1.1
# Pinecone monthly budget governor + storage autopilot
# PINECONE_RU_SOFT_LIMIT=0
# PINECONE_WU_SOFT_LIMIT=0
# PINECONE_AUTO_DISABLE_READS_ON_RU_EXHAUST=true
# PINECONE_AUTO_DISABLE_WRITES_ON_WU_EXHAUST=true
# PINECONE_AUTO_EVICT_ON_STORAGE_FULL=true
# PINECONE_STORAGE_EVICT_BATCH=200
# PINECONE_STORAGE_EVICT_SCAN_PAGES=10
# PINECONE_STORAGE_REALLOCATE_WAIT_MS=20000
# PINECONE_STORAGE_MAX_EVICTION_RETRIES=3
# PINECONE_GOVERNOR_LOG_COOLDOWN_MS=60000

# --- ATR sizing, confidence sizing, partial exits ---
ACCOUNT_EQUITY=500000
RISK_PER_TRADE_PCT=0.01
ATR_PERIOD=14
ATR_STOP_MULTIPLE=1.5
ATR_TARGET_MULTIPLE=2.5
ATR_TRAIL_TRIGGER_MULTIPLE=1.0
ATR_TRAIL_DIST_MULTIPLE=0.75
MAX_QTY_PER_TRADE=500
# Notional cap per trade as % of equity (0.25 = 25%)
MAX_NOTIONAL_PER_TRADE_PCT=0.25
MIN_QTY_PER_TRADE=1
ATR_EXITS_ENABLED=true
ATR_SIZING_ENABLED=true
CONFIDENCE_SCALE_FACTOR=1.5
CONFIDENCE_SIZING_ENABLED=false
CONFIDENCE_MULTIPLIER_MAX=1.3
# Confidence calibration (runtime): blends raw confidence with empirical bucket outcomes.
CONFIDENCE_CALIBRATION_ENABLED=true
CONFIDENCE_CALIBRATION_LOOKBACK_DAYS=45
CONFIDENCE_CALIBRATION_MIN_SAMPLES=80
CONFIDENCE_CALIBRATION_WEIGHT=0.5
PARTIAL_EXITS_ENABLED=true
PARTIAL_EXIT_1_ATR_MULTIPLE=1.0
PARTIAL_EXIT_1_QTY_PCT=0.33
PARTIAL_EXIT_2_ATR_MULTIPLE=2.0
PARTIAL_EXIT_2_QTY_PCT=0.33

# --- Strategy auto-gate ---
STRATEGY_AUTO_GATE_ENABLED=true
STRATEGY_GATE_WINDOW=20
# Require this many closed trades before auto-gate can disable a strategy
# Lowered from 40: 40 trades before gating means a catastrophically bad strategy runs for weeks
STRATEGY_GATE_MIN_TRADES=12
STRATEGY_GATE_MIN_PF=0.8
STRATEGY_GATE_MIN_WIN_RATE=0.3
# Decay-weighted gate: recent trades matter more than old trades.
STRATEGY_GATE_DECAY_ENABLED=true
STRATEGY_GATE_DECAY_HALFLIFE_TRADES=10
# Re-enable flow: strategy can come back after cooldown + recent improvement.
STRATEGY_REENABLE_ENABLED=true
STRATEGY_REENABLE_COOLDOWN_DAYS=2
STRATEGY_REENABLE_RECENT_TRADES=8
STRATEGY_REENABLE_MIN_PF=1.05
STRATEGY_REENABLE_MIN_WIN_RATE=0.45

# --- Strategy toggles (this week's paper profile) ---
BACKTEST_POSITION_QTY=10
BACKTEST_ENABLE_ORB_15M=true
BACKTEST_ENABLE_ORB_RETEST_15M=false
BACKTEST_ENABLE_MEAN_REV_Z=true
BACKTEST_ENABLE_BIG_BOY_SWEEP=true
BACKTEST_ENABLE_VWAP_RECLAIM_REJECT=true
BACKTEST_ENABLE_VWAP_PULLBACK_TREND=true
BACKTEST_ENABLE_PREV_DAY_HIGH_LOW_BREAK_RETEST=false
BACKTEST_ENABLE_EMA20_BREAK_RETEST=true
BACKTEST_ENABLE_VWAP_RECLAIM_CONTINUATION=true
BACKTEST_ENABLE_INITIAL_BALANCE_BREAK_RETEST=false
BACKTEST_ENABLE_VOLATILITY_CONTRACTION_BREAKOUT=false
BACKTEST_ENABLE_INSIDE_BAR_BREAKOUT_WITH_RETEST=false
BACKTEST_ENABLE_OPEN_DRIVE_PULLBACK=true
BACKTEST_ENABLE_ORB_FAKEOUT_REVERSAL=true
# EMA9 vs EMA21 ribbon trend-pullback — fires more frequently than VWAP_PULLBACK_TREND
BACKTEST_ENABLE_EMA_RIBBON_TREND=true
# Large momentum candle (>1.5x ATR) with volume — not vol-gated, self-filtering across all regimes
BACKTEST_ENABLE_CANDLE_MOMENTUM_SURGE=true
# Bull/bear flag breakout — tight consolidation after strong move; HIGH vol self-filters
BACKTEST_ENABLE_TREND_FLAG_BREAKOUT=true
# Confirmed VWAP reversal — waits for first reversal bar after overextension (higher accuracy)
BACKTEST_ENABLE_VWAP_REVERSAL_CONFIRMATION=true
# 5-min ORB break after 10:15am — fast ORB with volume confirmation
BACKTEST_ENABLE_FIVE_MIN_ORB_BREAK=true
# Session high/low breakout after 2h of price discovery — trend continuation
BACKTEST_ENABLE_SESSION_HIGH_LOW_BREAK=true
# Engulfing candle with volume surge — clear momentum reversal signal
BACKTEST_ENABLE_ENGULFING_WITH_VOLUME=true
# Nifty-50 index/laggard catch-up (NIFTY50 + 5d 1m history + heavyweight symbol required)
BACKTEST_ENABLE_INDEX_LAGGARD_CATCHUP=true
INDEX_LAGGARD_NIFTY_PCT5D_MIN=0.8
INDEX_LAGGARD_TICKER_PCT5D_MAX=0.2
INDEX_LAGGARD_NIFTY_SESSION_MIN_FROM_OPEN_PCT=0.05
INDEX_LAGGARD_MIN_VOLUME_Z=0.25
DISCOVERY_SYNC_INDEX_LAGGARD_UNIVERSE=true
LIVE_EXEC_SYNC_SUPPLEMENT_LAGGARD_UNIVERSE=true
# static = baked-in list; dynamic = NSE ind_nifty50list + top N by LTP×volume (Angel quote, rate-limited)
NIFTY_HEAVYWEIGHTS_MODE=static
NIFTY_HEAVYWEIGHTS_TOP_N=10
# Gap between NSE static CSV fetches (not SmartAPI)
NSE_ARCHIVES_MIN_GAP_MS=10000

# Volatility regime switch
# HIGH threshold raised to 0.35 — 0.22 was too aggressive, blocked ORB/VWAP on normal trending days.
# Lookback 20 bars (not 30) so mid-session calming re-opens the gate faster.
VOL_REGIME_SWITCH_ENABLED=true
VOL_REGIME_LOOKBACK_BARS=20
VOL_REGIME_LOW_MAX_PCT=0.08
VOL_REGIME_HIGH_MIN_PCT=0.35
VOL_REGIME_ORB_LOW=true
VOL_REGIME_ORB_MID=true
VOL_REGIME_ORB_HIGH=false
VOL_REGIME_MEANREV_LOW=false
VOL_REGIME_MEANREV_MID=true
VOL_REGIME_MEANREV_HIGH=true
VOL_REGIME_BIGBOY_LOW=false
VOL_REGIME_BIGBOY_MID=true
VOL_REGIME_BIGBOY_HIGH=true
VOL_REGIME_VWAP_LOW=true
VOL_REGIME_VWAP_MID=true
VOL_REGIME_VWAP_HIGH=false

# --- Backtest realism (microstructure + charges) ---
# Master toggle. Set false to revert to near-frictionless fills.
BACKTEST_REALISM_ENABLED=true
# 0 = signal-bar fill, 1 = next-bar-open fill (latency model)
BACKTEST_ENTRY_LATENCY_BARS=1
# If stop and target hit in same candle, choose adverse outcome.
BACKTEST_PESSIMISTIC_INTRABAR=true
# Spread/slippage/impact model (basis points)
BACKTEST_SPREAD_BPS=2.0
BACKTEST_BASE_SLIPPAGE_BPS=1.0
BACKTEST_IMPACT_BPS_PER_1PCT_PARTICIPATION=0.15
BACKTEST_VOLATILITY_SLIPPAGE_COEFF=0.1
# Fees/taxes model
BACKTEST_FEES_ENABLED=true
BACKTEST_BROKERAGE_PCT=0.0003
BACKTEST_BROKERAGE_CAP_PER_ORDER=20
BACKTEST_STT_SELL_PCT=0.00025
BACKTEST_EXCHANGE_TXN_PCT=0.0000297
BACKTEST_SEBI_PCT=0.000001
BACKTEST_GST_PCT=0.18
BACKTEST_STAMP_DUTY_BUY_PCT=0.00003
